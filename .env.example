# Polymarket wallet private key (export from Polymarket → Cash → ··· → Export Private Key)
POLY_PRIVATE_KEY=

# Polymarket signing address (derived from private key)
POLY_WALLET_ADDRESS=
# Polymarket funder/proxy address (shown in Relayer API Keys section)
POLY_FUNDER_ADDRESS=

# Free tier API keys
NEWS_API_KEY=         # https://newsapi.org (free: 100 req/day)
ODDS_API_KEY=         # https://the-odds-api.com (free: 500 req/month)

# Bot settings
BOT_BUDGET_USDC=10.0         # starting budget in USDC
BOT_MAX_POSITION_PCT=0.30    # max % of budget per trade (30%)
BOT_KELLY_FRACTION=0.25      # fractional Kelly (conservative: 1/4)
BOT_MIN_EDGE=0.05            # minimum edge to place a bet (5%)
BOT_SCAN_INTERVAL_SEC=300    # how often to scan markets (5 min)
